# Шаблон конфигурации. Скопируйте в .env и подставьте свои значения.
# Сгенерировать надёжный ключ: python -c "import secrets; print(secrets.token_hex(32))"
ANONYMIZER_API_KEY=change-me
# 127.0.0.1 — только локальный доступ. Для доступа по сети: 0.0.0.0 + reverse-proxy с TLS.
ANONYMIZER_HOST=127.0.0.1
ANONYMIZER_PORT=8077
